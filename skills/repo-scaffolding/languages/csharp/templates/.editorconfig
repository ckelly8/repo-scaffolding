# Baseline-and-ratchet. Analyzers + warnings-as-errors are ON (Directory.Build.props);
# any rule that currently fires in a target repo is dialed DOWN here (suggestion/silent)
# so the build stays green today. Burn the baselined set down over time — each rule moved
# back up to warning/error is debt repaid. New/changed code already meets the full bar.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4
dotnet_sort_system_directives_first = true
csharp_new_line_before_open_brace = all
csharp_prefer_braces = true:warning

# --- Full-bar rules (stay at warning/error) ---
dotnet_diagnostic.CA2007.severity = none          # ConfigureAwait — app code, not a library; off by choice
dotnet_style_namespace_match_folder = true:warning

# --- Baselined debt (dialed down so a brownfield build stays green; ratchet upward) ---
# Each line below is a rule that commonly fires on existing code. Move back to `warning`
# as the target repo cleans up. This list IS the documented debt.
dotnet_diagnostic.CA1707.severity = suggestion    # underscores in member names (test methods)
dotnet_diagnostic.CA1822.severity = suggestion    # member can be static
dotnet_diagnostic.IDE0058.severity = silent       # expression value never used
dotnet_diagnostic.IDE0008.severity = silent       # use explicit type instead of var

[*.{json,yml,yaml}]
indent_size = 2

[*.{props,targets,csproj,config}]
indent_size = 2
