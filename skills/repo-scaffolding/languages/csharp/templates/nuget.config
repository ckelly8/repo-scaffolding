<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Single locked source. <clear/> drops any machine/user-level source so a restore
       can only pull from nuget.org — no silent fallback feed. Pair with a locked restore
       (the pre-push hook runs `dotnet restore` in locked mode) so the committed
       packages.lock.json is law. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
